# Local scripts only (e.g. node update_images.cjs) — not used by the Vite app
SERPER_API_KEY=

# Vercel / server: Project Settings → Environment Variables (never commit real keys)
# Used by api/product-insights.js (product modal → Load AI summaries & safe searches)

# At least one provider:

# Claude (Anthropic) — default order tries this first if the key is set:
ANTHROPIC_API_KEY=

# Gemini — your own API key from Google AI Studio (direct API, not Vercel):
GEMINI_API_KEY=
# GOOGLE_AI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
# GOOGLE_API_KEY=

# Optional: only if you use Vercel AI Gateway’s key (different from a Google Gemini key):
# GEMINI_AI_GATEWAY_API_KEY=
# AI_GATEWAY_API_KEY=
# AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1
# AI_GATEWAY_GEMINI_MODEL=google/gemini-2.5-flash

OPENAI_API_KEY=

# Supabase client (used to store health intake by authenticated user id)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: try providers in order (default: claude,openai — no Gemini unless you add it).
# Anthropic only: AI_INSIGHTS_PROVIDER_ORDER=claude
# Include Gemini: AI_INSIGHTS_PROVIDER_ORDER=claude,gemini,openai

# Optional model overrides
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# GEMINI_MODEL=gemini-2.0-flash

# api/llm-recommendations.js — AI-generated tiered recommendations from health intake (no catalog shortlist)
# Default provider order: anthropic,openai,gemini. Example Claude-only:
# AI_RECOMMENDATIONS_PROVIDER_ORDER=anthropic
