# Vercel / server: Project Settings → Environment Variables (never commit real keys)
# Used by api/product-insights.js (product modal → Load AI summaries & safe searches)

# At least one provider:
# Vercel AI Gateway (recommended if you added Gemini / models in the Vercel dashboard):
AI_GATEWAY_API_KEY=
# Optional: override default https://ai-gateway.vercel.sh/v1 and google/gemini-2.5-flash
# AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1
# AI_GATEWAY_GEMINI_MODEL=google/gemini-2.5-flash

ANTHROPIC_API_KEY=
# Direct Gemini / Google AI (AI Studio key): any one of these names works (used if Gateway fails or is unset)
GEMINI_API_KEY=
# GOOGLE_AI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
# GOOGLE_API_KEY=
OPENAI_API_KEY=

# Optional: try providers in order (default: claude,gemini,openai). Only providers with keys run.
# AI_INSIGHTS_PROVIDER_ORDER=gemini,openai

# Optional model overrides
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022
# GEMINI_MODEL=gemini-2.0-flash
